# Cerberus brand identity. Source this before running build.sh / dev/build.sh
# to lock in the values consumed by utils.sh and prepare_vscode.sh.

export APP_NAME="Cerberus"
export BINARY_NAME="cerberus"
export ORG_NAME="AiwebModel"
export GH_REPO_PATH="aiwebmodel/cerberus"
export ASSETS_REPOSITORY="aiwebmodel/cerberus"
export TUNNEL_APP_NAME="cerberus-tunnel"

# Cerberus AI provider (consumed by built-in cerberus-ai extension via product.json)
export CERBERUS_HOMEPAGE_URL="https://ide.aiwebmodel.com"
export CERBERUS_DOCS_URL="https://ide.aiwebmodel.com/docs"
# IDE extension panel'a bağlanır; /api/ai/chat ve /api/models sufix'leri client tarafında eklenir.
export CERBERUS_AI_API_BASE_URL="https://ide.aiwebmodel.com"
